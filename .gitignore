# ─────────────────────────────────────────────
#  .gitignore — Clinical API
#  Node.js + TypeScript + SQLite + Express
# ─────────────────────────────────────────────


# ── Dependências ──────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ── TypeScript compilado ──────────────────────
dist/
build/
out/


# ── Banco de dados local ──────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal


# ── Variáveis de ambiente ─────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local


# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ── Cache e temporários ───────────────────────
.cache/
.temp/
.tmp/
tmp/
temp/
*.tsbuildinfo


# ── IDEs e editores ───────────────────────────

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
Session.vim

# Emacs
\#*\#
.\#*


# ── Sistema operacional ───────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory


# ── Testes e cobertura ────────────────────────
coverage/
*.lcov
.nyc_output/


# ── Ferramentas de qualidade ──────────────────
.eslintcache
.stylelintcache
.prettiercache


# ── Package managers ──────────────────────────
.npm/
.pnpm-store/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml